---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/paths';

const events = [
  {
    id: 'spring-mahamudra-retreat-2026',
    title: 'Spring Mahamudra Retreat',
    dateStart: 'April 14, 2026',
    dateEnd:   'April 20, 2026',
    month: 'Apr',
    day: '14',
    type: 'Residential Retreat',
    online: false,
    location: 'Norbu Ling, Bir, Himachal Pradesh, India',
    description: 'A seven-day residential retreat on the nature of mind according to the Mahamudra tradition of the Kagyu lineage. Each day comprises early-morning practice sessions, a formal teaching, guided meditation, and a question-and-answer period. The retreat is conducted in silence from sunset to the following morning. Participants are expected to have completed the Ngondro or to have a stable foundation in shamatha meditation.',
    prerequisites: 'Completion of Ngondro or demonstrated shamatha stability',
    fee: 'Dana (contribution-based). Accommodation at Norbu Ling: ₹1,200/night shared, ₹2,200/night private.',
    register: '#',
  },
  {
    id: 'online-bodhicitta-weekend-may-2026',
    title: 'Introduction to Bodhicitta',
    dateStart: 'May 16, 2026',
    dateEnd:   'May 17, 2026',
    month: 'May',
    day: '16',
    type: 'Online Teaching',
    online: true,
    location: 'Live via Zoom',
    description: 'A weekend online teaching exploring the awakening of compassion through the Seven-Point Mind Training (Lojong) of Chekawa Yeshe Dorje. This course is suitable for complete beginners as well as experienced practitioners wishing to refresh their foundation. All talks will be recorded and made available to registered participants for 30 days.',
    prerequisites: 'None — open to all',
    fee: 'Free of charge. Registration required.',
    register: '#',
  },
  {
    id: 'tsok-june-2026',
    title: 'Guru Rinpoche Tsok Feast and Empowerment',
    dateStart: 'June 21, 2026',
    dateEnd:   'June 23, 2026',
    month: 'Jun',
    day: '21',
    type: 'Ceremony',
    online: false,
    location: 'Norbu Ling, Bir, Himachal Pradesh, India',
    description: 'A three-day sacred gathering on the tenth day of the Tibetan lunar month (Guru Rinpoche Day). The programme includes the Tsok offering ceremony, the Guru Rinpoche empowerment (Wang), and teaching on the Kagyu Guru Yoga. This event is held three times annually at Norbu Ling and is one of its most beloved gatherings.',
    prerequisites: 'Refuge vows recommended but not required for the teaching',
    fee: 'Dana. Accommodation available at Norbu Ling — contact office to book.',
    register: '#',
  },
  {
    id: 'ngondro-transmission-july-2026',
    title: 'Ngondro Transmission and Instruction',
    dateStart: 'July 5, 2026',
    dateEnd:   'July 6, 2026',
    month: 'Jul',
    day: '5',
    type: 'Transmission',
    online: false,
    location: 'Norbu Ling, Bir, Himachal Pradesh, India',
    description: 'Lama Karma Dorje will give the reading transmission (lung) and full explanatory teaching for the Kagyu Ngondro — the four foundation practices comprising 100,000 each of prostrations, Vajrasattva purification, mandala offering, and Guru Yoga. This transmission authorises recipients to begin the practice. A follow-up online Q&A session is offered one month after the transmission.',
    prerequisites: 'Refuge vows. Students who do not yet have refuge vows may take them at this event.',
    fee: 'Dana. Attendance is in-person only for this event.',
    register: '#',
  },
  {
    id: 'lojong-online-august-2026',
    title: 'Working with Difficult Emotions: A Lojong Weekend',
    dateStart: 'August 8, 2026',
    dateEnd:   'August 9, 2026',
    month: 'Aug',
    day: '8',
    type: 'Online Teaching',
    online: true,
    location: 'Live via Zoom',
    description: 'A practical two-day online seminar on the mind-training (Lojong) tradition — specifically its approach to transforming anger, fear, and grief into the path of compassion. Drawing on the classic texts of Chekawa, Shantideva, and the oral instructions of his own teachers, Lama Karma Dorje will offer both philosophical grounding and immediate practical exercises.',
    prerequisites: 'None — open to all. Suitable for those with a secular mindfulness background.',
    fee: 'Free of charge. Registration required. Recording available for 60 days.',
    register: '#',
  },
  {
    id: 'autumn-three-day-retreat-2026',
    title: 'Autumn Shamatha and Vipashyana Retreat',
    dateStart: 'October 3, 2026',
    dateEnd:   'October 5, 2026',
    month: 'Oct',
    day: '3',
    type: 'Residential Retreat',
    online: false,
    location: 'Norbu Ling, Bir, Himachal Pradesh, India',
    description: 'A three-day silent residential retreat on the twin pillars of Buddhist meditation: shamatha (calm abiding) and vipashyana (insight). Suitable for practitioners of all traditions. The retreat provides an ideal foundation for those planning to undertake longer retreats in the future. Guidance on posture, breath, and working with distraction will be given in accessible, non-technical language.',
    prerequisites: 'Some prior meditation experience recommended',
    fee: 'Dana. Accommodation: ₹1,200/night shared, ₹2,200/night private.',
    register: '#',
  },
  {
    id: 'milarepa-teaching-november-2026',
    title: 'Songs of Milarepa: A Teaching Series',
    dateStart: 'November 14, 2026',
    dateEnd:   'November 16, 2026',
    month: 'Nov',
    day: '14',
    type: 'Online Teaching',
    online: true,
    location: 'Live via Zoom',
    description: 'Three evenings of teaching on selected songs from the Milarepa canon, exploring their hidden Mahamudra meaning and their relevance to contemporary practice. Lama Karma Dorje will draw on his book Songs of Milarepa: A Practitioner\'s Guide (2019), though the teachings are self-contained and no prior familiarity with the text is needed.',
    prerequisites: 'None — open to all',
    fee: 'Free of charge. Donations gratefully received.',
    register: '#',
  },
  {
    id: 'winter-dzogchen-december-2026',
    title: 'Winter Retreat: Dzogchen Pointing-Out Instructions',
    dateStart: 'December 19, 2026',
    dateEnd:   'December 28, 2026',
    month: 'Dec',
    day: '19',
    type: 'Residential Retreat',
    online: false,
    location: 'Norbu Ling, Bir, Himachal Pradesh, India',
    description: 'A ten-day closed residential retreat on the Dzogchen pointing-out instructions received from Tulku Urgyen Rinpoche. This retreat is strictly limited to practitioners who have completed the Ngondro, have a stable shamatha foundation, and have received prior instruction from Lama Karma Dorje or a teacher he has recognised. Applications must be submitted at least three months in advance.',
    prerequisites: 'Completion of Ngondro. Prior instruction from an authorised teacher. Application required.',
    fee: 'Dana. Application opens September 2026. Capacity: 12 students.',
    register: '#',
  },
];
---

<Base
  title="Teaching Schedule"
  description="Upcoming teachings, retreats, and empowerments with Lama Karma Dorje — in person at Norbu Ling, Bir and online worldwide."
>

  <!-- ── Page Hero ──────────────────────────────────────────── -->
  <section class="page-hero">
    <div class="page-hero-content">
      <span class="hero-eyebrow" style="margin-bottom:1rem;">2026 Programme</span>
      <h1>Teaching Schedule</h1>
      <p>Upcoming teachings, retreats, and empowerments at Norbu Ling and via live stream. All are welcome.</p>
    </div>
  </section>

  <!-- ── Notice ─────────────────────────────────────────────── -->
  <section style="background:var(--color-bg-warm);padding:2rem 0;">
    <div class="container" style="max-width:820px;">
      <div class="notice-box">
        <strong>Registration and enquiries:</strong> To register for any event, please contact the office at <a href="mailto:office@lamakarmadorje.org">office@lamakarmadorje.org</a>. For residential retreats, early registration is strongly advised as places are limited. Online teachings are free of charge and open to all.
      </div>
    </div>
  </section>

  <!-- ── Schedule List ──────────────────────────────────────── -->
  <section class="section" style="background:var(--color-bg);">
    <div class="container" style="max-width:900px;">
      <div class="schedule-list">
        {events.map(e => (
          <article class="schedule-event" id={e.id}>
            <div class="schedule-event-header">
              <h3>{e.title}</h3>
              <span class={`event-tag ${e.online ? 'event-tag--online' : ''}`}>
                {e.online ? 'Online' : 'In Person'}
              </span>
            </div>
            <div class="schedule-event-body">
              <div class="schedule-event-meta">
                <span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {e.dateStart}{e.dateEnd !== e.dateStart ? ` — ${e.dateEnd}` : ''}
                </span>
                <span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {e.location}
                </span>
                <span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {e.type}
                </span>
              </div>
              <p>{e.description}</p>
              <div style="display:grid;grid-template-columns:1fr;gap:0.75rem;margin-bottom:1.25rem;" class="event-details-grid">
                <div>
                  <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.25rem;">Prerequisites</p>
                  <p style="font-size:0.875rem;color:var(--color-text);">{e.prerequisites}</p>
                </div>
                <div>
                  <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.25rem;">Dana / Fees</p>
                  <p style="font-size:0.875rem;color:var(--color-text);">{e.fee}</p>
                </div>
              </div>
              <a href={withBase('/contact/')} class="btn btn--primary btn--sm">
                Register / Enquire →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Past Events Note ──────────────────────────────────── -->
  <section class="section--sm" style="background:var(--color-bg-warm);">
    <div class="container" style="max-width:820px;text-align:center;">
      <span class="section-eyebrow">Recordings</span>
      <h2 style="font-size:2rem;color:var(--color-primary);margin-bottom:1rem;">Previous Teachings</h2>
      <p style="color:var(--color-text-muted);max-width:580px;margin:0 auto 1.75rem;">
        Audio recordings of selected past teachings are available for free download from the Norbu Ling audio archive. Video recordings of online sessions are made available to registered participants for a limited period after each event.
      </p>
      <a href={withBase('/contact/')} class="btn btn--outline">Request Archive Access</a>
    </div>
  </section>

</Base>

<style>
  @media (min-width: 640px) {
    .event-details-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
