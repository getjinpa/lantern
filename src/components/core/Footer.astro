---
import { withBase } from '../../utils/paths';

interface Props {
  siteConfig: any;
}
const { siteConfig } = Astro.props;
const contact = siteConfig.contact || {};
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href={withBase('/')} class="site-logo" aria-label="Home" style="text-decoration:none;">
          <span class="site-logo-name" style="color:#fff;font-family:'Playfair Display',Georgia,serif;">Lama Karma Dorje</span>
        </a>
        <p style="margin-top:0.75rem;">
          Tibetan Buddhist teacher, retreat master, and lineage holder of the Kagyu tradition. Based in Bir, Himachal Pradesh, India.
        </p>
        <!-- Social -->
        <div class="footer-social" style="margin-top:1.25rem;">
          <a href="#" aria-label="Facebook" title="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" title="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- About -->
      <div class="footer-col">
        <h4>About</h4>
        <ul>
          <li><a href={withBase('/biography/')}>Biography</a></li>
          <li><a href={`${withBase('/biography/')}#lineage`}>Lineage</a></li>
          <li><a href={`${withBase('/biography/')}#publications`}>Publications</a></li>
          <li><a href={withBase('/contact/')}>Media Enquiries</a></li>
        </ul>
      </div>

      <!-- Teachings -->
      <div class="footer-col">
        <h4>Teachings</h4>
        <ul>
          <li><a href={withBase('/teachings/')}>Overview</a></li>
          <li><a href={`${withBase('/teachings/')}#mahamudra`}>Mahamudra</a></li>
          <li><a href={`${withBase('/teachings/')}#bodhicitta`}>Bodhicitta</a></li>
          <li><a href={withBase('/schedule/')}>Schedule</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          {contact.address && <li><span style="color:rgba(255,255,255,0.45);font-size:0.875rem;line-height:1.6;">{contact.address}</span></li>}
          {contact.email  && <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>}
          <li><a href={withBase('/contact/')}>Send a message</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span>&copy; {year} Lama Karma Dorje. All rights reserved.</span>
      <span>
        Built with <a href="https://getjinpa.github.io" target="_blank" rel="noopener noreferrer">Jinpa</a>
      </span>
    </div>
  </div>
</footer>
